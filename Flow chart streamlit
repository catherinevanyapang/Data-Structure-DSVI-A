<!DOCTYPE html>
<html lang="id">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Streamlit Tutorial — Flowchart & Mind Map</title>
<style>
  :root {
    --bg: #0F172A;
    --surface: #1E293B;
    --surface2: #273548;
    --accent: #FF4B4B;
    --blue: #3B82F6;
    --green: #22C55E;
    --purple: #A855F7;
    --amber: #F59E0B;
    --teal: #14B8A6;
    --pink: #EC4899;
    --text: #F1F5F9;
    --muted: #94A3B8;
    --border: #334155;
    --navy: #1E3A5F;
  }
  * { box-sizing: border-box; margin: 0; padding: 0; }
  body {
    background: var(--bg);
    color: var(--text);
    font-family: 'Segoe UI', system-ui, sans-serif;
    min-height: 100vh;
  }

  /* ── Nav tabs ── */
  .tabs {
    display: flex;
    background: var(--surface);
    border-bottom: 1px solid var(--border);
    padding: 0 24px;
    gap: 4px;
  }
  .tab {
    padding: 14px 24px;
    cursor: pointer;
    font-size: 13px;
    font-weight: 600;
    color: var(--muted);
    border-bottom: 3px solid transparent;
    transition: all .2s;
    letter-spacing: .5px;
    text-transform: uppercase;
  }
  .tab.active { color: var(--accent); border-bottom-color: var(--accent); }
  .tab:hover:not(.active) { color: var(--text); }

  .panel { display: none; padding: 32px 24px; }
  .panel.active { display: block; }

  h1 { font-size: 22px; font-weight: 700; margin-bottom: 6px; }
  .subtitle { font-size: 13px; color: var(--muted); margin-bottom: 32px; }

  /* ══════════════════════════════════════
     FLOWCHART
  ══════════════════════════════════════ */
  .flow-wrap {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0;
    max-width: 700px;
    margin: 0 auto;
  }

  /* node */
  .node {
    display: flex;
    align-items: center;
    gap: 14px;
    background: var(--surface);
    border: 1.5px solid var(--border);
    border-radius: 12px;
    padding: 14px 20px;
    width: 100%;
    transition: transform .15s, box-shadow .15s;
    position: relative;
  }
  .node:hover { transform: translateX(4px); box-shadow: -4px 0 0 var(--c, var(--accent)); }
  .node-icon {
    width: 40px; height: 40px; border-radius: 10px;
    display: flex; align-items: center; justify-content: center;
    font-size: 18px; flex-shrink: 0;
  }
  .node-text { flex: 1; }
  .node-num {
    font-size: 10px; font-weight: 700; letter-spacing: 1px;
    color: var(--muted); text-transform: uppercase; margin-bottom: 2px;
  }
  .node-title { font-size: 14px; font-weight: 700; }
  .node-desc { font-size: 12px; color: var(--muted); margin-top: 2px; line-height: 1.5; }
  .node-tag {
    font-size: 10px; font-weight: 600; padding: 3px 10px; border-radius: 20px;
    white-space: nowrap;
  }

  /* arrow */
  .arrow {
    width: 2px; height: 28px;
    background: linear-gradient(to bottom, var(--from), var(--to));
    margin: 0 auto;
    position: relative;
  }
  .arrow::after {
    content: '';
    position: absolute;
    bottom: -1px; left: 50%;
    transform: translateX(-50%);
    border: 6px solid transparent;
    border-top-color: var(--to);
  }

  /* decision diamond */
  .diamond-wrap {
    display: flex;
    flex-direction: column;
    align-items: center;
    width: 100%;
  }
  .diamond {
    background: var(--surface2);
    border: 2px solid var(--amber);
    border-radius: 6px;
    transform: rotate(45deg);
    width: 120px; height: 120px;
    display: flex; align-items: center; justify-content: center;
    margin: 8px 0;
  }
  .diamond-inner {
    transform: rotate(-45deg);
    text-align: center;
    font-size: 12px; font-weight: 700;
    color: var(--amber);
    line-height: 1.3;
  }
  .diamond-branches {
    display: flex;
    gap: 80px;
    align-items: flex-start;
    margin-top: 4px;
  }
  .branch { display: flex; flex-direction: column; align-items: center; }
  .branch-label {
    font-size: 11px; font-weight: 700; border-radius: 20px;
    padding: 2px 10px; margin-bottom: 6px;
  }
  .branch-node {
    background: var(--surface);
    border: 1.5px solid var(--border);
    border-radius: 10px;
    padding: 10px 14px;
    font-size: 12px;
    text-align: center;
    width: 130px;
    line-height: 1.4;
  }

  /* ══════════════════════════════════════
     MIND MAP
  ══════════════════════════════════════ */
  #mindmap-canvas {
    width: 100%;
    height: 620px;
    position: relative;
    overflow: hidden;
  }
  #mindmap-svg {
    position: absolute; top: 0; left: 0;
    width: 100%; height: 100%;
    pointer-events: none;
  }
  .mm-node {
    position: absolute;
    border-radius: 10px;
    padding: 8px 14px;
    font-size: 12px;
    font-weight: 600;
    text-align: center;
    transform: translate(-50%, -50%);
    cursor: default;
    transition: transform .2s, box-shadow .2s;
    line-height: 1.4;
    white-space: nowrap;
    z-index: 2;
  }
  .mm-node:hover { transform: translate(-50%,-50%) scale(1.08); z-index: 10; }
  .mm-root {
    background: var(--accent);
    color: white;
    font-size: 15px;
    font-weight: 800;
    padding: 14px 22px;
    border-radius: 14px;
    box-shadow: 0 0 30px rgba(255,75,75,.4);
  }
  .mm-folder {
    border: 2px solid;
    color: white;
  }
  .mm-file {
    border: 1.5px solid;
    font-size: 11px;
    font-weight: 500;
    padding: 6px 12px;
  }
  .mm-badge {
    font-size: 9px; letter-spacing: .5px;
    font-weight: 700; opacity: .75;
    text-transform: uppercase;
  }

  /* legend */
  .legend {
    display: flex; flex-wrap: wrap; gap: 16px;
    margin-bottom: 24px;
  }
  .legend-item {
    display: flex; align-items: center; gap: 8px;
    font-size: 12px; color: var(--muted);
  }
  .legend-dot {
    width: 14px; height: 14px; border-radius: 4px;
  }
</style>
</head>
<body>

<div class="tabs">
  <div class="tab active" onclick="show('flow')">🔄 Flowchart Alur Kerja</div>
  <div class="tab" onclick="show('mind')">🗂️ Mind Map Struktur File</div>
</div>

<!-- ══════════════════════════════════════ FLOWCHART ══════════════════════════ -->
<div class="panel active" id="panel-flow">
  <h1>Flowchart Tutorial Streamlit</h1>
  <p class="subtitle">Alur lengkap dari instalasi Python hingga aplikasi live di internet</p>

  <div class="flow-wrap">

    <!-- START -->
    <div class="node" style="--c:#22C55E; border-color:#22C55E; background:#052e16;">
      <div class="node-icon" style="background:#15803d;">🟢</div>
      <div class="node-text">
        <div class="node-num">Mulai</div>
        <div class="node-title" style="color:#22C55E;">START — Python Sudah Terinstal</div>
        <div class="node-desc">Pastikan Python 3.x sudah terpasang di komputer</div>
      </div>
    </div>

    <div class="arrow" style="--from:#22C55E; --to:#3B82F6;"></div>

    <!-- T1 -->
    <div class="node" style="--c:#3B82F6; border-color:#3B82F6;">
      <div class="node-icon" style="background:#1e40af;">🔍</div>
      <div class="node-text">
        <div class="node-num">Tahap 1</div>
        <div class="node-title">Cari Lokasi Instalasi Python</div>
        <div class="node-desc"><code style="font-family:monospace;font-size:11px;background:#1e293b;padding:1px 6px;border-radius:4px;">where python</code> &nbsp;(Windows) atau &nbsp;<code style="font-family:monospace;font-size:11px;background:#1e293b;padding:1px 6px;border-radius:4px;">which python</code> &nbsp;(Mac/Linux)</div>
      </div>
      <span class="node-tag" style="background:#1e40af; color:#93c5fd;">CMD / Terminal</span>
    </div>

    <div class="arrow" style="--from:#3B82F6; --to:#8B5CF6;"></div>

    <!-- T2 -->
    <div class="node" style="--c:#8B5CF6; border-color:#8B5CF6;">
      <div class="node-icon" style="background:#4c1d95;">📁</div>
      <div class="node-text">
        <div class="node-num">Tahap 2</div>
        <div class="node-title">Buat Folder Proyek & Buka di VS Code</div>
        <div class="node-desc">Buat folder di Documents/Desktop → File > Open Folder di VS Code → Atur PowerShell RLS: <code style="font-family:monospace;font-size:11px;">Set-ExecutionPolicy RemoteSigned</code></div>
      </div>
      <span class="node-tag" style="background:#4c1d95; color:#c4b5fd;">VS Code</span>
    </div>

    <div class="arrow" style="--from:#8B5CF6; --to:#14B8A6;"></div>

    <!-- T3 -->
    <div class="node" style="--c:#14B8A6; border-color:#14B8A6;">
      <div class="node-icon" style="background:#134e4a;">🐍</div>
      <div class="node-text">
        <div class="node-num">Tahap 3</div>
        <div class="node-title">Buat Virtual Environment (.venv)</div>
        <div class="node-desc">Ctrl+Shift+P → Python: Create Environment → Venv → Pilih interpreter → Restart terminal → Cek tanda <code style="font-family:monospace;font-size:11px;color:#4ade80;">(.venv)</code></div>
      </div>
      <span class="node-tag" style="background:#134e4a; color:#5eead4;">VS Code UI</span>
    </div>

    <div class="arrow" style="--from:#14B8A6; --to:#F59E0B;"></div>

    <!-- T4 -->
    <div class="node" style="--c:#F59E0B; border-color:#F59E0B;">
      <div class="node-icon" style="background:#78350f;">📦</div>
      <div class="node-text">
        <div class="node-num">Tahap 4</div>
        <div class="node-title">Install Streamlit</div>
        <div class="node-desc"><code style="font-family:monospace;font-size:11px;background:#1e293b;padding:1px 6px;border-radius:4px;">pip install streamlit</code> &nbsp;→ verifikasi dengan &nbsp;<code style="font-family:monospace;font-size:11px;background:#1e293b;padding:1px 6px;border-radius:4px;">streamlit --version</code></div>
      </div>
      <span class="node-tag" style="background:#78350f; color:#fcd34d;">pip</span>
    </div>

    <div class="arrow" style="--from:#F59E0B; --to:#EC4899;"></div>

    <!-- T5 -->
    <div class="node" style="--c:#EC4899; border-color:#EC4899;">
      <div class="node-icon" style="background:#831843;">✍️</div>
      <div class="node-text">
        <div class="node-num">Tahap 5</div>
        <div class="node-title">Tulis Kode di app.py</div>
        <div class="node-desc">Buat file app.py → Tulis kode Streamlit (st.title, st.write, st.button, st.sidebar, dll) → Simpan Ctrl+S</div>
      </div>
      <span class="node-tag" style="background:#831843; color:#f9a8d4;">Python</span>
    </div>

    <div class="arrow" style="--from:#EC4899; --to:#FF4B4B;"></div>

    <!-- T6 -->
    <div class="node" style="--c:#FF4B4B; border-color:#FF4B4B;">
      <div class="node-icon" style="background:#7f1d1d;">▶️</div>
      <div class="node-text">
        <div class="node-num">Tahap 6</div>
        <div class="node-title">Jalankan Aplikasi Lokal</div>
        <div class="node-desc"><code style="font-family:monospace;font-size:11px;background:#1e293b;padding:1px 6px;border-radius:4px;">streamlit run app.py</code> &nbsp;→ Buka <code style="font-family:monospace;font-size:11px;">localhost:8501</code> → Aktifkan Always Rerun → Ctrl+C untuk stop</div>
      </div>
      <span class="node-tag" style="background:#7f1d1d; color:#fca5a5;">localhost</span>
    </div>

    <div class="arrow" style="--from:#FF4B4B; --to:#6366F1;"></div>

    <!-- T7 -->
    <div class="node" style="--c:#6366F1; border-color:#6366F1;">
      <div class="node-icon" style="background:#312e81;">📝</div>
      <div class="node-text">
        <div class="node-num">Tahap 7A</div>
        <div class="node-title">Buat requirements.txt & .gitignore</div>
        <div class="node-desc">requirements.txt ← <code style="font-family:monospace;font-size:11px;">streamlit</code> &nbsp;|&nbsp; .gitignore ← <code style="font-family:monospace;font-size:11px;">.venv/ __pycache__/</code></div>
      </div>
      <span class="node-tag" style="background:#312e81; color:#a5b4fc;">File</span>
    </div>

    <div class="arrow" style="--from:#6366F1; --to:#0EA5E9;"></div>

    <!-- T7B Git -->
    <div class="node" style="--c:#0EA5E9; border-color:#0EA5E9;">
      <div class="node-icon" style="background:#0c4a6e;">🔧</div>
      <div class="node-text">
        <div class="node-num">Tahap 7B</div>
        <div class="node-title">Init Git & Commit Pertama</div>
        <div class="node-desc"><code style="font-family:monospace;font-size:11px;background:#1e293b;padding:1px 6px;border-radius:4px;">git init</code> → <code style="font-family:monospace;font-size:11px;background:#1e293b;padding:1px 6px;border-radius:4px;">git add .</code> → <code style="font-family:monospace;font-size:11px;background:#1e293b;padding:1px 6px;border-radius:4px;">git commit -m "..."</code> → <code style="font-family:monospace;font-size:11px;background:#1e293b;padding:1px 6px;border-radius:4px;">git branch -M main</code></div>
      </div>
      <span class="node-tag" style="background:#0c4a6e; color:#7dd3fc;">Git</span>
    </div>

    <div class="arrow" style="--from:#0EA5E9; --to:#10B981;"></div>

    <!-- T7C GitHub -->
    <div class="node" style="--c:#10B981; border-color:#10B981;">
      <div class="node-icon" style="background:#064e3b;">🐙</div>
      <div class="node-text">
        <div class="node-num">Tahap 7C</div>
        <div class="node-title">Buat Repo GitHub & Push</div>
        <div class="node-desc">github.com → New repository (Public) → Salin perintah remote → <code style="font-family:monospace;font-size:11px;background:#1e293b;padding:1px 6px;border-radius:4px;">git remote add origin ...</code> → <code style="font-family:monospace;font-size:11px;background:#1e293b;padding:1px 6px;border-radius:4px;">git push -u origin main</code></div>
      </div>
      <span class="node-tag" style="background:#064e3b; color:#6ee7b7;">GitHub</span>
    </div>

    <div class="arrow" style="--from:#10B981; --to:#FF4B4B;"></div>

    <!-- T8 Deploy -->
    <div class="node" style="--c:#FF4B4B; border-color:#FF4B4B; background:#1a0505;">
      <div class="node-icon" style="background:#7f1d1d;">🚀</div>
      <div class="node-text">
        <div class="node-num">Tahap 8</div>
        <div class="node-title">Deploy ke Streamlit Cloud</div>
        <div class="node-desc">share.streamlit.io → Sign in GitHub → New app → Pilih repo & branch main → Main file: app.py → Deploy!</div>
      </div>
      <span class="node-tag" style="background:#7f1d1d; color:#fca5a5;">Cloud</span>
    </div>

    <div class="arrow" style="--from:#FF4B4B; --to:#22C55E;"></div>

    <!-- END -->
    <div class="node" style="--c:#22C55E; border-color:#22C55E; background:#052e16;">
      <div class="node-icon" style="background:#15803d;">🌐</div>
      <div class="node-text">
        <div class="node-num">Selesai</div>
        <div class="node-title" style="color:#22C55E;">Aplikasi Live di Internet! 🎉</div>
        <div class="node-desc">Bagikan link Streamlit Cloud-mu ke siapa saja</div>
      </div>
    </div>

  </div>
</div>

<!-- ══════════════════════════════════════ MIND MAP ══════════════════════════ -->
<div class="panel" id="panel-mind">
  <h1>Mind Map Struktur Proyek</h1>
  <p class="subtitle">Folder dan file yang dibuat di VS Code selama tutorial ini</p>

  <div class="legend">
    <div class="legend-item"><div class="legend-dot" style="background:#FF4B4B;"></div>Root Proyek</div>
    <div class="legend-item"><div class="legend-dot" style="background:#3B82F6;"></div>Folder Python / venv</div>
    <div class="legend-item"><div class="legend-dot" style="background:#22C55E;"></div>File Python</div>
    <div class="legend-item"><div class="legend-dot" style="background:#F59E0B;"></div>File Konfigurasi</div>
    <div class="legend-item"><div class="legend-dot" style="background:#A855F7;"></div>File Git</div>
    <div class="legend-item"><div class="legend-dot" style="background:#14B8A6;"></div>Folder tersembunyi</div>
  </div>

  <div id="mindmap-canvas">
    <svg id="mindmap-svg"></svg>
    <!-- Nodes injected by JS -->
  </div>
</div>

<script>
// ── Tab switching ─────────────────────────────────────────────────────────────
function show(id) {
  document.querySelectorAll('.panel').forEach(p => p.classList.remove('active'));
  document.querySelectorAll('.tab').forEach(t => t.classList.remove('active'));
  document.getElementById('panel-' + id).classList.add('active');
  event.target.classList.add('active');
  if (id === 'mind') drawMindMap();
}

// ── Mind Map ──────────────────────────────────────────────────────────────────
function drawMindMap() {
  const canvas = document.getElementById('mindmap-canvas');
  const svg = document.getElementById('mindmap-svg');
  const W = canvas.offsetWidth;
  const H = canvas.offsetHeight;
  const cx = W / 2, cy = H / 2;

  // Clear previous
  canvas.querySelectorAll('.mm-node').forEach(n => n.remove());
  svg.innerHTML = '';

  // Node definitions: [id, label, x_offset_from_center, y_offset, type, color, bg, extra_desc]
  const nodes = [
    // Root
    { id: 'root', label: '📁 proyek-streamlit', x: cx, y: cy,
      cls: 'mm-root', bg: '#FF4B4B', color: '#fff', desc: '' },

    // Main files (right side)
    { id: 'app', label: '🐍 app.py', x: cx + 230, y: cy - 120,
      cls: 'mm-file mm-folder', bg: '#052e16', border: '#22C55E', color: '#86efac', desc: 'File utama Streamlit' },
    { id: 'req', label: '📄 requirements.txt', x: cx + 240, y: cy,
      cls: 'mm-file mm-folder', bg: '#1c1107', border: '#F59E0B', color: '#fcd34d', desc: 'Daftar library' },
    { id: 'gitignore', label: '🚫 .gitignore', x: cx + 230, y: cy + 120,
      cls: 'mm-file mm-folder', bg: '#1a0a2e', border: '#A855F7', color: '#d8b4fe', desc: 'Abaikan .venv dll' },

    // .venv folder (left)
    { id: 'venv', label: '📂 .venv/', x: cx - 230, y: cy - 90,
      cls: 'mm-folder', bg: '#0c2a3a', border: '#14B8A6', color: '#5eead4', desc: 'Virtual environment' },
    { id: 'venv_lib', label: '📦 lib/', x: cx - 380, y: cy - 150,
      cls: 'mm-file', bg: '#0f2535', border: '#0e7490', color: '#67e8f9', desc: 'Library terinstal' },
    { id: 'venv_scripts', label: '⚙️ Scripts/', x: cx - 390, y: cy - 70,
      cls: 'mm-file', bg: '#0f2535', border: '#0e7490', color: '#67e8f9', desc: 'Aktivasi & pip' },
    { id: 'venv_pyvenv', label: '📝 pyvenv.cfg', x: cx - 375, y: cy + 10,
      cls: 'mm-file', bg: '#0f2535', border: '#0e7490', color: '#67e8f9', desc: 'Konfigurasi venv' },

    // .git folder (left bottom)
    { id: 'git', label: '🔧 .git/', x: cx - 220, y: cy + 110,
      cls: 'mm-folder', bg: '#1a0a2e', border: '#8B5CF6', color: '#c4b5fd', desc: 'Repositori Git lokal' },
    { id: 'git_config', label: '📄 config', x: cx - 350, y: cy + 170,
      cls: 'mm-file', bg: '#150821', border: '#7C3AED', color: '#ddd6fe', desc: 'Pengaturan remote' },
    { id: 'git_commits', label: '📜 COMMIT_EDITMSG', x: cx - 190, y: cy + 200,
      cls: 'mm-file', bg: '#150821', border: '#7C3AED', color: '#ddd6fe', desc: 'Pesan commit terakhir' },

    // Streamlit cache (right bottom)
    { id: 'cache', label: '🗃️ __pycache__/', x: cx + 80, y: cy + 180,
      cls: 'mm-folder', bg: '#1c1107', border: '#78716C', color: '#a8a29e', desc: 'Cache Python (diabaikan Git)' },
  ];

  // Connections: [from_id, to_id, color]
  const edges = [
    ['root', 'app',      '#22C55E'],
    ['root', 'req',      '#F59E0B'],
    ['root', 'gitignore','#A855F7'],
    ['root', 'venv',     '#14B8A6'],
    ['root', 'git',      '#8B5CF6'],
    ['root', 'cache',    '#78716C'],
    ['venv', 'venv_lib',    '#0e7490'],
    ['venv', 'venv_scripts','#0e7490'],
    ['venv', 'venv_pyvenv', '#0e7490'],
    ['git', 'git_config',  '#7C3AED'],
    ['git', 'git_commits', '#7C3AED'],
  ];

  // Draw edges
  const nodeMap = {};
  nodes.forEach(n => nodeMap[n.id] = n);

  edges.forEach(([a, b, color]) => {
    const na = nodeMap[a], nb = nodeMap[b];
    const line = document.createElementNS('http://www.w3.org/2000/svg', 'path');
    const dx = nb.x - na.x, dy = nb.y - na.y;
    const mx = na.x + dx * 0.5;
    line.setAttribute('d', `M${na.x},${na.y} C${mx},${na.y} ${mx},${nb.y} ${nb.x},${nb.y}`);
    line.setAttribute('stroke', color);
    line.setAttribute('stroke-width', '1.5');
    line.setAttribute('fill', 'none');
    line.setAtt
